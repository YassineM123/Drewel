PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
# jsonwebtoken duration syntax, for example: 30m, 8h, or 1d
ADMIN_JWT_EXPIRES_IN=8h
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=drewel-app
MONGO_FORCE_IPV4=true
ALLOW_START_WITHOUT_DB=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://admin-dreewel.com,https://www.admin-dreewel.com

# File storage
# Use "local" for development uploads under ./public, or "s3" for AWS S3.
STORAGE_DRIVER=local
# Optional canonical origin used in uploaded asset URLs (no trailing slash).
# Recommended behind a reverse proxy so saved URLs do not depend on Host headers.
PUBLIC_API_URL=https://admin-dreewel.com
# Optional comma-separated origins found in legacy stored asset URLs.
LEGACY_ASSET_ORIGINS=
# Number of known reverse-proxy hops. Keep 0 unless the topology is known;
# PUBLIC_API_URL is the preferred production origin.
TRUST_PROXY_HOPS=0
AWS_REGION=us-east-1
AWS_S3_BUCKET=drewel-app-uploads
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key

# Meta WhatsApp Cloud API
# Use the Phone number ID from Meta Developers > WhatsApp > API Setup.
# This is not the phone number, WABA ID, app ID, or page ID.
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EA...
WHATSAPP_API_VERSION=v19.0
WHATSAPP_TEMPLATE_NAME=login_otp_verification
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_VERIFY_CONFIG_BEFORE_SEND=false

# Set true for local development when Meta credentials are not ready.
WHATSAPP_MOCK_OTP=false

# Twilio SMS OTP (required when using the SMS login/forgot-password flow)
TWILIOSID=replace-with-twilio-account-sid
TWILIOTOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000
